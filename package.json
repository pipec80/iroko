{
  "name": "saasboilerplate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "dev:clean": "rimraf .next && next dev --turbo",
    "clean": "rimraf .next",
    "build": "next build",
    "postbuild": "next-sitemap && node scripts/prepare-standalone.mjs",
    "start": "node .next/standalone/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "audit": "pnpm audit --prod --audit-level=high",
    "audit:full": "pnpm audit",
    "deps:update": "pnpm update --latest",
    "deps:outdated": "pnpm outdated",
    "security:gitleaks": "gitleaks detect --source .",
    "security:all": "pnpm audit && pnpm security:gitleaks",
    "validate": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test",
    "validate:full": "pnpm validate && pnpm test:e2e",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "analyze": "cross-env ANALYZE=true next build",
    "prepare": "husky",
    "--- VERCEL ---": "",
    "vercel:env": "vercel env pull .env.local",
    "vercel:dev": "vercel dev",
    "vercel:deploy": "vercel deploy",
    "vercel:deploy:prod": "vercel deploy --prod",
    "vercel:build": "vercel build",
    "vercel:logs": "vercel logs",
    "--- SUPABASE LOCAL (SAFE) ---": "",
    "supa:start": "supabase start",
    "supa:stop": "supabase stop",
    "supa:restart": "supabase stop && supabase start",
    "supa:status": "supabase status",
    "supa:studio": "echo Studio: http://127.0.0.1:54323 && echo Inbucket: http://127.0.0.1:54324",
    "supa:fix-ports": "docker restart supabase_studio_saas-boilerplate supabase_kong_saas-boilerplate",
    "supa:reset": "supabase db reset --local",
    "supa:diff": "supabase db diff --local",
    "supa:lint": "supabase db lint --local",
    "supa:advisors": "supabase db advisors --local",
    "supa:test": "supabase test db --local",
    "supa:migration:new": "supabase migration new",
    "supa:migration:list": "supabase migration list --local",
    "supa:migration:up": "supabase migration up --local",
    "supa:inspect:bloat": "supabase inspect db bloat --local",
    "supa:inspect:outliers": "supabase inspect db outliers --local",
    "supa:inspect:locks": "supabase inspect db locks --local",
    "supa:inspect:vacuum": "supabase inspect db vacuum-stats --local",
    "supa:inspect:traffic": "supabase inspect db traffic-profile --local",
    "--- SUPABASE GEN ---": "",
    "supa:gen:types": "supabase gen types --local --lang typescript --schema public,billing,audit > src/types/database.ts",
    "supa:gen:types:check": "git diff --exit-code src/types/database.ts",
    "supa:gen:types:cloud": "supabase gen types --linked --lang typescript --schema public,billing,audit > src/types/database.ts",
    "supa:gen:seed-buckets": "supabase seed buckets --local",
    "supa:cloud:seed-buckets": "supabase seed buckets --linked",
    "--- SUPABASE CLOUD (⚠️ DESTRUCTIVE) ---": "",
    "supa:cloud:link": "supabase link",
    "supa:cloud:push": "supabase db push --linked",
    "supa:cloud:push:dry": "supabase db push --linked --dry-run",
    "supa:cloud:pull": "supabase db pull --linked",
    "supa:cloud:dump": "supabase db dump --linked -f supabase/schema.dump.sql",
    "supa:cloud:migration:list": "supabase migration list --linked",
    "supa:cloud:advisors": "supabase db advisors --linked",
    "supa:cloud:config:push": "supabase config push"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.5.3",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^10.49.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.3",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/react-query": "^5.99.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.7",
    "next-intl": "^4.13.0",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-country-flag": "^3.1.0",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.8",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "knip": "^6.6.1",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rimraf": "^6.1.3",
    "shadcn": "^4.4.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.8"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": ">=3.1.2",
      "ws": ">=8.20.1",
      "postcss": ">=8.5.10",
      "hono": ">=4.12.21",
      "qs": ">=6.15.2",
      "ip-address": ">=10.1.1"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
