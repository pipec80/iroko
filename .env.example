# ============================================================================
# Ambiente
# ============================================================================
NODE_ENV=development
LOG_LEVEL=info
SITE_URL=http://localhost:3000

# ============================================================================
# Supabase (client — expuestas al browser)
# ============================================================================
# Obtener con: supabase status -o env
# API_URL local por defecto: http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Nueva publishable key (formato sb_publishable_*). Reemplaza a anon key legacy.
# Ver: https://github.com/orgs/supabase/discussions/29260
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# ============================================================================
# Supabase (server — NUNCA exponer al cliente)
# ============================================================================
# Nueva secret key (formato sb_secret_*). Reemplaza a service_role legacy.
# Solo usada en src/lib/supabase/admin.ts y webhooks server-side.
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

# ============================================================================
# OAuth providers (opcionales para local — configurar en supabase/config.toml)
# ============================================================================
# GOOGLE_OAUTH_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET=
# MICROSOFT_OAUTH_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_AZURE_CLIENT_SECRET=

# ============================================================================
# Stripe (módulo billing — siguiente iteración)
# ============================================================================
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxx
