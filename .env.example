# ============================================================================
# Ambiente
# ============================================================================
NODE_ENV=development
LOG_LEVEL=info
SITE_URL=http://localhost:3000

# ============================================================================
# Supabase (client — expuestas al browser)
# ============================================================================
# Obtener con: supabase status -o env
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Nueva publishable key (formato sb_publishable_*). Reemplaza anon key legacy.
# Ver: https://github.com/orgs/supabase/discussions/29260
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# ============================================================================
# Supabase (server — NUNCA exponer al cliente)
# ============================================================================
# Nueva secret key (formato sb_secret_*). Reemplaza service_role legacy.
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

# ============================================================================
# OAuth — Google
# ============================================================================
# Crear en: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=GOCSPX-your-client-secret

# ============================================================================
# Sentry (opcional en desarrollo)
# ============================================================================
# DSN: https://iroko.sentry.io/settings/projects/iroko/keys/
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o123456.ingest.us.sentry.io/your-project-id
# Auth token para source maps: https://iroko.sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=sntryu_your-auth-token-here

# ============================================================================
# Stripe (módulo billing — próxima iteración)
# ============================================================================
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxx