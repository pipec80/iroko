# ─────────────────────────────────────────────
# Supabase (required)
# ─────────────────────────────────────────────

# Public URL of your Supabase project (client + server)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Publishable (anon) key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<anon-key>

# Service-role secret key — server-side only, never expose to the client
SUPABASE_SECRET_KEY=<service-role-key>

# ─────────────────────────────────────────────
# App (optional — defaults shown)
# ─────────────────────────────────────────────

# Canonical URL used in sitemap and canonical tags (default: http://localhost:3000)
SITE_URL=https://yourdomain.com

# Pino log level: fatal | error | warn | info | debug | trace | silent (default: info)
# LOG_LEVEL=info

# ─────────────────────────────────────────────
# Sentry (optional)
# ─────────────────────────────────────────────

# DSN for error tracking (client + server). Omit to disable Sentry.
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>

# Auth token for source-map upload during `next build` (CI only)
# SENTRY_AUTH_TOKEN=<token>

# ─────────────────────────────────────────────
# Cloudflare Turnstile CAPTCHA (optional)
# ─────────────────────────────────────────────

# Site key shown on auth forms. Pair with [auth.captcha] in supabase/config.toml.
# Local always-pass test key: 1x00000000000000000000AA
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=<site-key>

# ─────────────────────────────────────────────
# CI only
# ─────────────────────────────────────────────

# Set to 1 in Dependabot PRs (no secrets available) to skip env validation during build
# SKIP_ENV_VALIDATION=1

# ─────────────────────────────────────────────
# Email — Resend (required for transactional email)
# ─────────────────────────────────────────────

# API key from resend.com (free tier: 3 000 emails/month)
# In local dev, Resend sends real emails — use your own address for testing.
# Supabase Auth emails (signup confirm, magic link) go through Inbucket at http://127.0.0.1:54324
RESEND_API_KEY=re_<your-api-key>

# "From" address for transactional emails — must be a verified domain in Resend
FROM_EMAIL=noreply@yourdomain.com
# Billing (F2-2A-core) — mock provider, sin credenciales de proveedor real aún
MOCK_BILLING_SECRET=dev-mock-secret-change-me
BILLING_DEFAULT_PROVIDER=mock
